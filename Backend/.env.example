# База данных (Supabase / PostgreSQL)
# Используй свою собственную БД — локальную или бесплатный Supabase-проект
DATABASE_URL=postgresql://user:password@localhost:5432/solidsearch

# Шифрование пользовательских API-ключей (AES-256-CBC)
# Сгенерируй свою: openssl rand -hex 32
ENCRYPTION_KEY=your_32_byte_hex_encryption_key

# Сервер
PORT=3000

# LLM API-ключ НЕ указывается здесь.
# Каждый пользователь добавляет свой ключ через интерфейс приложения после регистрации —
# ключ шифруется (AES-256-CBC) и хранится в базе данных, привязанным к аккаунту.